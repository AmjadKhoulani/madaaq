<IfModule mod_rewrite.c>
  Options -Indexes
  RewriteEngine On
  RewriteBase /

  # 1. API - Forward directly to PHP bridge
  RewriteRule ^api/(.*)$ api/index.php [L]

  # 2. Redirect /cp to /cp/ (ensure trailing slash for assets)
  RewriteRule ^cp$ /cp/ [R=301,L]

  # 3. ROOT - Landing Page (Pure Static)
  # If it's not the API and not CP, and not a real file
  RewriteCond %{REQUEST_URI} !^/api [NC]
  RewriteCond %{REQUEST_URI} !^/cp [NC]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
