<IfModule mod_rewrite.c>
  Options -Indexes
  RewriteEngine On
  RewriteBase /

  # 1. API - Forward directly to PHP bridge
  RewriteRule ^api/(.*)$ api/index.php [L]

  # 2. CP (Sub-folder SPA)
  # Any request to /cp/... that is not a real file or directory
  RewriteCond %{REQUEST_URI} ^/cp [NC]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  # Send it to /cp/index.html
  RewriteRule ^cp/.*$ /cp/index.html [L]

  # 3. ROOT (Landing Page)
  # If it's not the API and not CP, and not a real file
  RewriteCond %{REQUEST_URI} !^/api [NC]
  RewriteCond %{REQUEST_URI} !^/cp [NC]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
